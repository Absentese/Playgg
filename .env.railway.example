# Скопируйте в Variables → Raw Editor на Railway (после создания Postgres).
# APP_KEY: php artisan key:generate --show (локально)

APP_NAME=playgg
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
APP_TIMEZONE=Europe/Moscow

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=pgsql
DATABASE_URL=${{Postgres.DATABASE_URL}}

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

BROADCAST_CONNECTION=log
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@playgg.ru
MAIL_FROM_NAME="${APP_NAME}"

# Один раз после первого деплоя: RAILWAY_RUN_SEED=1, Redeploy, затем удалите переменную.
# RAILWAY_RUN_SEED=1
